{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Webpack App (Firefox)",
      "type": "firefox",
      "request": "launch",
      "url": "http://localhost:3000/index.html",
      "webRoot": "${workspaceFolder}/dist",
      "pathMappings": [
        {
          "url": "webpack://webapp/",
          "path": "${workspaceFolder}"
        }
      ],
      "reloadOnAttach": true
    },
    {
      "name": "Debug Webpack App (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000/index.html",
      "webRoot": "${workspaceFolder}/dist",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:///*": "${workspaceFolder}/*"
      }
    }
  ]
}
